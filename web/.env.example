# Stripe configuration
# Test mode key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=

# Product price identifier created in your Stripe dashboard
STRIPE_PRICE_ID=

# Optional: override checkout mode (subscription or payment). Defaults to subscription.
# STRIPE_CHECKOUT_MODE=subscription

# Optional: base URL used when headers are unavailable (e.g. background jobs)
# NEXT_PUBLIC_SITE_URL=https://app.greenfundr.com
